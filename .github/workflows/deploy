name: Test OIDC

on:
  push:
    branches: [main]

jobs:
  test:
    runs-on: ubuntu-latest

    permissions:
      id-token: write
      contents: read

    steps:
      - uses: actions/checkout@v3

      - name: Configure AWS
        uses: aws-actions/configure-aws-credentials@v2
        with:
          role-to-assume: <PASTE_YOUR_ROLE_ARN>
          aws-region: us-east-2

      - name: Test Identity
        run: aws sts get-caller-identity
